---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated } from '../../lib/auth';
import db from '../../lib/db';
import bcrypt from 'bcryptjs';

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}

let message = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const upsert = db.prepare('INSERT OR REPLACE INTO settings (key, value) VALUES (?, ?)');

  for (const [key, value] of formData.entries()) {
    if (key === 'new_password') {
      const pwd = (value as string).trim();
      if (pwd) {
        const hash = await bcrypt.hash(pwd, 12);
        upsert.run('admin_password', hash);
      }
    } else {
      upsert.run(key, value);
    }
  }

  message = 'Impostazioni salvate.';
}

const settingsRaw = db.prepare('SELECT * FROM settings').all() as { key: string; value: string }[];
const s = Object.fromEntries(settingsRaw.map(r => [r.key, r.value]));
---

<BaseLayout title="Impostazioni — Giuseppe Lupo">
  <div class="admin-wrapper">
    <nav class="admin-nav dotted-border-b">
      <div class="mono-logo">G. LUPO / ADMIN</div>
      <div class="nav-links">
        <a href="/admin/dashboard">DASHBOARD</a>
        <a href="/admin/settings" class="active">IMPOSTAZIONI</a>
        <a href="/admin/logout" style="color: var(--accent-red); text-decoration: none;">ESCI</a>
        <a href="/" class="home-link">← SITO</a>
      </div>
    </nav>

    <main class="admin-main">
      <div class="header-section">
        <h1 class="serif">Preferenze</h1>
        {message && <div class="alert-success">{message}</div>}
      </div>

      <div class="settings-grid">

        {/* ── Profilo ── */}
        <section class="admin-card">
          <div class="card-header mono">◆ PROFILO E CONTATTI</div>
          <form method="POST" class="admin-form">
            <div class="field">
              <label>EMAIL PUBBLICA</label>
              <input type="email" name="email" value={s.email} required />
            </div>
            <div class="field">
              <label>INSTAGRAM HANDLE</label>
              <input type="text" name="ig_handle" value={s.ig_handle} placeholder="@username" />
            </div>
            <div class="field">
              <label>LINK BIO / ALTRI SOCIAL</label>
              <input type="text" name="social_links" value={s.social_links ?? ''} placeholder="URL separati da virgola" />
            </div>
            <div class="separator">
              <div class="card-header mono" style="margin-bottom:12px">SICUREZZA</div>
              <div class="field">
                <label>CAMBIA PASSWORD (lascia vuoto per non modificare)</label>
                <input type="password" name="new_password" placeholder="Nuova password…" />
              </div>
            </div>
            <button type="submit" class="primary">SALVA</button>
          </form>
        </section>

        {/* ── Servizio Stampa ── */}
        <section class="admin-card">
          <div class="card-header mono">◆ SERVIZIO STAMPA FINE ART</div>
          <form method="POST" class="admin-form">
            <div class="field">
              <label>TESTO INTRODUTTIVO</label>
              <textarea name="print_intro" rows="3">{s.print_intro}</textarea>
            </div>
            <div class="row-2">
              <div class="field">
                <label>FORMATI DISPONIBILI (uno per riga)</label>
                <textarea name="print_sizes" rows="5">{s.print_sizes}</textarea>
              </div>
              <div class="field">
                <label>TIPI DI CARTA (uno per riga)</label>
                <textarea name="print_papers" rows="5">{s.print_papers}</textarea>
              </div>
            </div>
            <div class="row-2">
              <div class="field">
                <label>COPIE PER EDIZIONE</label>
                <input type="number" min="1" name="print_edition" value={s.print_edition} />
              </div>
              <div class="field">
                <label>TEMPO DI RISPOSTA INDICATIVO</label>
                <input type="text" name="print_response_time" value={s.print_response_time} placeholder="es. entro 48 ore" />
              </div>
            </div>
            <button type="submit" class="primary">SALVA</button>
          </form>
        </section>

        {/* ── Notifiche SMTP ── */}
        <section class="admin-card full-width">
          <div class="card-header mono">◆ NOTIFICHE EMAIL (SMTP)</div>
          <p class="hint">Configura un account SMTP per ricevere un'email ogni volta che arriva una richiesta di stampa. Con Gmail usa <code>smtp.gmail.com</code> porta <code>587</code> e una <em>App Password</em>.</p>
          <form method="POST" class="admin-form">
            <div class="row-4">
              <div class="field">
                <label>HOST SMTP</label>
                <input type="text" name="smtp_host" value={s.smtp_host ?? ''} placeholder="smtp.gmail.com" />
              </div>
              <div class="field" style="flex:0 0 100px">
                <label>PORTA</label>
                <input type="number" name="smtp_port" value={s.smtp_port ?? '587'} />
              </div>
              <div class="field">
                <label>UTENTE (email mittente)</label>
                <input type="email" name="smtp_user" value={s.smtp_user ?? ''} placeholder="tuo@gmail.com" />
              </div>
              <div class="field">
                <label>PASSWORD / APP PASSWORD</label>
                <input type="password" name="smtp_pass" value={s.smtp_pass ?? ''} placeholder="••••••••••••••••" />
              </div>
            </div>
            <div class="field" style="max-width:320px">
              <label>EMAIL DI DESTINAZIONE NOTIFICHE</label>
              <input type="email" name="notify_email" value={s.notify_email ?? s.email} />
            </div>
            <button type="submit" class="primary">SALVA</button>
          </form>
        </section>

      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .admin-wrapper { min-height: 100vh; background: var(--bg-home); }
  .admin-nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 44px; }
  .mono-logo { font-size: 13px; letter-spacing: 2.5px; font-weight: 500; }
  .nav-links { display: flex; gap: 24px; font-size: 10px; letter-spacing: 2px; }
  .nav-links a { color: var(--text-45); text-decoration: none; }
  .nav-links a.active { color: var(--text-primary); }
  .home-link { color: var(--text-primary) !important; border: 1px solid var(--text-45); padding: 4px 10px; font-size: 9px; letter-spacing: 2px; }

  .admin-main { padding: 40px 44px; max-width: 1300px; margin: 0 auto; }
  .header-section { margin-bottom: 48px; }
  h1 { font-size: 48px; margin: 0; }
  .alert-success { margin-top: 16px; background: rgba(232,226,212,0.05); border: 1px solid var(--text-14); padding: 12px 20px; font-size: 12px; }

  .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .full-width { grid-column: 1 / -1; }

  .admin-card { border: 1px solid var(--border-subtle); padding: 32px; }
  .card-header { font-size: 10px; letter-spacing: 2.5px; opacity: 0.5; margin-bottom: 24px; }

  .admin-form { display: flex; flex-direction: column; gap: 20px; }
  .field { display: flex; flex-direction: column; gap: 7px; }
  .field label { font-size: 9px; letter-spacing: 2px; opacity: 0.45; font-family: var(--font-mono); }
  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .row-4 { display: grid; grid-template-columns: 1fr 100px 1fr 1fr; gap: 16px; align-items: end; }
  .separator { padding-top: 24px; border-top: 1px solid var(--border-subtle); }

  input, textarea, select {
    width: 100%; background: var(--bg-frame); border: 1px solid var(--border-subtle);
    padding: 10px 14px; color: var(--text-primary); font-family: var(--font-mono);
    font-size: 12px; outline: none; box-sizing: border-box;
  }
  textarea { resize: vertical; }
  input:focus, textarea:focus { border-color: var(--text-45); }
  code { font-family: var(--font-mono); font-size: 11px; opacity: 0.7; }

  button.primary { background: var(--text-primary); color: #000; border: none; padding: 13px; font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px; cursor: pointer; }
  button.primary:hover { opacity: 0.88; }

  .hint { font-size: 11px; opacity: 0.5; line-height: 1.6; margin: -8px 0 20px; }
</style>
