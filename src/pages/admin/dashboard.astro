---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { isAuthenticated } from '../../lib/auth';
import db from '../../lib/db';
import exifr from 'exifr';
import fs from 'node:fs/promises';
import path from 'node:path';

if (!isAuthenticated(Astro.cookies)) {
  return Astro.redirect('/admin/login');
}

let message = '';

// Handle POST actions
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');

  if (action === 'create_story') {
    const title = formData.get('title') as string;
    const cat = formData.get('category') as string;
    const loc = formData.get('location') as string;
    const year = parseInt(formData.get('year') as string);

    const baseSlug = title.toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    let slug = baseSlug;
    let suffix = 2;
    while (db.prepare('SELECT 1 FROM stories WHERE slug = ?').get(slug)) {
      slug = `${baseSlug}-${suffix++}`;
    }

    const baseId = title.substring(0, 3).toUpperCase();
    let storyId = baseId + Math.floor(Math.random() * 900 + 100);
    while (db.prepare('SELECT 1 FROM stories WHERE id = ?').get(storyId)) {
      storyId = baseId + Math.floor(Math.random() * 900 + 100);
    }

    try {
      db.prepare('INSERT INTO stories (id, slug, cat, title, loc, year) VALUES (?, ?, ?, ?, ?, ?)')
        .run(storyId, slug, cat, title, loc, year);
      message = `Storia "${title}" creata con successo.`;
    } catch (e) {
      message = `Errore durante la creazione: ${(e as Error).message}`;
    }
  }

  if (action === 'upload_frames') {
    const storyId = formData.get('story_id') as string;
    const files = formData.getAll('photos') as File[];

    const ACCEPTED_TYPES = ['image/jpeg', 'image/jpg', 'image/png', 'image/webp', 'image/heic', 'image/heif'];
    let savedCount = 0;

    await fs.mkdir(path.join(process.cwd(), 'public', 'photos'), { recursive: true });

    for (const file of files) {
      if (!file.name || file.size === 0) continue;
      if (!ACCEPTED_TYPES.includes(file.type.toLowerCase()) && !file.name.match(/\.(jpe?g|png|webp|heic|heif)$/i)) continue;

      const buffer = Buffer.from(await file.arrayBuffer());
      const filename = `${Date.now()}-${file.name.replace(/[^a-zA-Z0-9._-]/g, '_')}`;
      const savePath = path.join(process.cwd(), 'public', 'photos', filename);

      await fs.writeFile(savePath, buffer);

      // Extract EXIF
      const metadata = await exifr.parse(buffer, {
        pick: ['Make', 'Model', 'LensModel', 'DateTimeOriginal', 'ExposureTime', 'FNumber', 'ISO', 'latitude', 'longitude']
      }).catch(() => null);

      const cameraData = JSON.stringify(metadata);
      const n = (Math.random() * 99).toFixed(0) + 'A';
      const src = `/photos/${filename}`;

      db.prepare('INSERT INTO frames (story_id, n, src, camera_data) VALUES (?, ?, ?, ?)')
        .run(storyId, n, src, cameraData);

      if (metadata?.latitude && metadata?.longitude) {
        db.prepare('UPDATE stories SET lat = ?, lng = ? WHERE id = ?')
          .run(metadata.latitude, metadata.longitude, storyId);
      }

      savedCount++;
    }
    message = `${savedCount} / ${files.length} foto caricate ed elaborate.`;
  }

  if (action === 'delete_story') {
    const storyId = formData.get('story_id') as string;
    const frames = db.prepare('SELECT src FROM frames WHERE story_id = ?').all(storyId) as { src: string }[];
    
    for (const f of frames) {
      try {
        const filePath = path.join(process.cwd(), 'public', f.src);
        await fs.unlink(filePath);
      } catch {}
    }
    
    db.prepare('DELETE FROM stories WHERE id = ?').run(storyId);
    message = 'Storia eliminata correttamente.';
  }

  if (action === 'update_print_status') {
    const reqId = formData.get('req_id') as string;
    const status = formData.get('status') as string;
    if (reqId && status) {
      db.prepare('UPDATE print_requests SET status = ? WHERE id = ?').run(status, reqId);
    }
  }

  if (action === 'delete_print_request') {
    const reqId = formData.get('req_id') as string;
    if (reqId) {
      db.prepare('DELETE FROM print_requests WHERE id = ?').run(reqId);
      message = 'Richiesta eliminata.';
    }
  }
}

const stories = db.prepare('SELECT * FROM stories').all() as any[];
const printRequests = db.prepare('SELECT * FROM print_requests ORDER BY created_at DESC').all() as any[];
---

<BaseLayout title="Dashboard Amministratore — Giuseppe Lupo">
  <div class="admin-wrapper">
    <nav class="admin-nav dotted-border-b">
      <div class="mono-logo">G. LUPO / ADMIN</div>
      <div class="nav-links">
        <a href="/admin/dashboard" class="active">DASHBOARD</a>
        <a href="/admin/settings">IMPOSTAZIONI</a>
        <a href="/admin/logout" class="logout-link">ESCI</a>
        <a href="/" class="home-link">← SITO</a>
      </div>
    </nav>

    <main class="admin-main">
      <div class="header-section">
        <h1 class="serif">Gestione Portfolio</h1>
        {message && <div class="alert-success">{message}</div>}
      </div>

      <div class="grid-section">
        <section class="admin-card">
          <div class="card-header mono">◆ NUOVA STORIA</div>
          <form method="POST" class="admin-form">
            <input type="hidden" name="action" value="create_story" />
            <input type="text" name="title" placeholder="Titolo" required />
            <input type="text" name="category" placeholder="Categoria (es. Reportage)" required />
            <div class="row">
              <input type="text" name="location" placeholder="Luogo" required />
              <input type="number" name="year" value={new Date().getFullYear()} required />
            </div>
            <button type="submit">CREA STORIA</button>
          </form>
        </section>

        <section class="admin-card">
          <div class="card-header mono">◆ CARICA FOTOGRAMMI</div>
          <form method="POST" enctype="multipart/form-data" class="admin-form" id="upload-form">
            <input type="hidden" name="action" value="upload_frames" />
            <select name="story_id" required>
              <option value="">Seleziona Storia...</option>
              {stories.map(s => <option value={s.id}>{s.title}</option>)}
            </select>
            <div class="file-input-wrapper" id="drop-zone">
              <input type="file" name="photos" accept="image/*" multiple required id="file-upload" />
              <label for="file-upload" class="file-label">
                <span id="file-label-text">SELEZIONA FILE O TRASCINA QUI</span>
              </label>
            </div>
            <div id="preview-section" style="display:none">
              <div class="preview-header">
                <span id="preview-count" class="mono"></span>
                <button type="button" id="clear-all-btn">RIMUOVI TUTTO</button>
              </div>
              <div id="preview-grid"></div>
            </div>
            <button type="submit" class="primary" id="upload-btn" style="display:none">CARICA E ANALIZZA EXIF</button>
          </form>
        </section>
      </div>

      <section class="stories-list">
        <div class="card-header mono">◆ STORIE PUBBLICATE ({stories.length})</div>
        <div class="stories-grid">
          {stories.map(s => (
            <div class="story-item">
              <div class="story-info">
                <span class="story-title serif">{s.title}</span>
                <span class="story-meta mono">{s.cat} ∙ {s.loc} ({s.year})</span>
              </div>
              <div class="story-actions">
                <a href={`/admin/storia/${s.id}`}>GESTISCI</a>
                <a href={`/storie/${s.slug}`} target="_blank">VEDI</a>
                <form method="POST" class="delete-story-form">
                  <input type="hidden" name="action" value="delete_story" />
                  <input type="hidden" name="story_id" value={s.id} />
                  <button type="submit" class="delete-btn">ELIMINA</button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="print-requests-section">
        <div class="card-header mono">◆ RICHIESTE STAMPA FINE ART ({printRequests.length})</div>
        {printRequests.length === 0 ? (
          <div class="empty-requests">Nessuna richiesta ricevuta.</div>
        ) : (
          <div class="print-requests-grid">
            {printRequests.map(r => (
              <div class={`print-request-card status-${r.status}`}>
                <div class="req-thumb">
                  {r.frame_src && <img src={r.frame_src} alt={r.frame_lbl} />}
                </div>
                <div class="req-body">
                  <div class="req-meta mono">{r.created_at?.slice(0, 10)} ∙ {r.story_title}</div>
                  <div class="req-lbl serif">{r.frame_lbl || '—'}</div>
                  <div class="req-specs mono">{r.size} ∙ {r.paper}</div>
                  <div class="req-contact">
                    <strong>{r.name}</strong> — <a href={`mailto:${r.email}`}>{r.email}</a>
                  </div>
                  {r.notes && <div class="req-notes">"{r.notes}"</div>}
                </div>
                <div class="req-actions">
                  <span class={`req-status status-badge-${r.status}`}>{r.status.toUpperCase()}</span>
                  <form method="POST" class="status-form">
                    <input type="hidden" name="action" value="update_print_status" />
                    <input type="hidden" name="req_id" value={String(r.id)} />
                    <select name="status" onchange="this.form.submit()" class="status-select">
                      <option value="pending" selected={r.status === 'pending'}>In attesa</option>
                      <option value="contacted" selected={r.status === 'contacted'}>Contattato</option>
                      <option value="confirmed" selected={r.status === 'confirmed'}>Confermato</option>
                      <option value="shipped" selected={r.status === 'shipped'}>Spedito</option>
                      <option value="closed" selected={r.status === 'closed'}>Chiuso</option>
                    </select>
                  </form>
                  <form method="POST" class="delete-req-form">
                    <input type="hidden" name="action" value="delete_print_request" />
                    <input type="hidden" name="req_id" value={String(r.id)} />
                    <button type="submit" class="delete-req-btn" title="Elimina richiesta">✕</button>
                  </form>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  document.querySelectorAll('.delete-story-form').forEach(form => {
    form.addEventListener('submit', (e) => {
      if (!confirm('ELIMINARE QUESTA STORIA?')) e.preventDefault();
    });
  });

  document.querySelectorAll('.delete-req-form').forEach(form => {
    form.addEventListener('submit', (e) => {
      if (!confirm('Eliminare questa richiesta di stampa?')) e.preventDefault();
    });
  });
</script>

<script>
  import exifr from 'exifr';

  const fileInput = document.getElementById('file-upload') as HTMLInputElement;
  const previewSection = document.getElementById('preview-section') as HTMLElement;
  const previewGrid = document.getElementById('preview-grid') as HTMLElement;
  const previewCount = document.getElementById('preview-count') as HTMLElement;
  const uploadBtn = document.getElementById('upload-btn') as HTMLElement;
  const clearAllBtn = document.getElementById('clear-all-btn') as HTMLElement;
  const dropZone = document.getElementById('drop-zone') as HTMLElement;
  const fileLabelText = document.getElementById('file-label-text') as HTMLElement;

  let selectedFiles: File[] = [];

  function formatExposure(t: number): string | null {
    if (!t) return null;
    if (t >= 1) return `${t}s`;
    return `1/${Math.round(1 / t)}s`;
  }

  function formatDate(d: Date | string): string | null {
    if (!d) return null;
    const dt = d instanceof Date ? d : new Date(d);
    return dt.toLocaleDateString('it-IT', { day: '2-digit', month: 'short', year: 'numeric' });
  }

  function createThumbnail(file: File, maxW = 400, maxH = 300): Promise<string> {
    return new Promise((resolve) => {
      const url = URL.createObjectURL(file);
      const img = new Image();
      img.onload = () => {
        URL.revokeObjectURL(url);
        const ratio = Math.min(maxW / img.width, maxH / img.height, 1);
        const canvas = document.createElement('canvas');
        canvas.width = Math.round(img.width * ratio);
        canvas.height = Math.round(img.height * ratio);
        canvas.getContext('2d')!.drawImage(img, 0, 0, canvas.width, canvas.height);
        resolve(canvas.toDataURL('image/jpeg', 0.75));
      };
      img.onerror = () => { URL.revokeObjectURL(url); resolve(''); };
      img.src = url;
    });
  }

  async function renderPreviews() {
    previewGrid.innerHTML = '';

    if (selectedFiles.length === 0) {
      previewSection.style.display = 'none';
      uploadBtn.style.display = 'none';
      fileLabelText.textContent = 'SELEZIONA FILE O TRASCINA QUI';
      return;
    }

    previewSection.style.display = 'block';
    uploadBtn.style.display = 'block';
    previewCount.textContent = `${selectedFiles.length} FOTO SELEZIONATE`;
    fileLabelText.textContent = '+ AGGIUNGI ALTRE FOTO';

    for (let i = 0; i < selectedFiles.length; i++) {
      const file = selectedFiles[i];
      const url = await createThumbnail(file);

      const card = document.createElement('div');
      card.className = 'preview-card';
      card.innerHTML = `
        <div class="preview-thumb">
          <img src="${url}" alt="${file.name}" />
          <button type="button" class="preview-remove" data-index="${i}" title="Rimuovi">✕</button>
        </div>
        <div class="preview-info">
          <div class="preview-filename">${file.name}</div>
          <div class="preview-exif" id="exif-${i}">
            <span class="exif-loading">lettura EXIF…</span>
          </div>
        </div>
      `;
      previewGrid.appendChild(card);

      exifr.parse(file, {
        pick: ['Make', 'Model', 'LensModel', 'ExposureTime', 'FNumber', 'ISO', 'DateTimeOriginal']
      }).then((exif: Record<string, any>) => {
        const el = document.getElementById(`exif-${i}`);
        if (!el) return;
        if (!exif) { el.innerHTML = '<span class="exif-none">nessun dato EXIF</span>'; return; }

        const tags = [
          exif.Model,
          exif.LensModel,
          formatExposure(exif.ExposureTime),
          exif.FNumber ? `f/${exif.FNumber}` : null,
          exif.ISO ? `ISO ${exif.ISO}` : null,
          formatDate(exif.DateTimeOriginal),
        ].filter(Boolean);

        el.innerHTML = tags.length
          ? tags.map(t => `<span class="exif-tag">${t}</span>`).join('')
          : '<span class="exif-none">nessun dato EXIF</span>';
      }).catch(() => {
        const el = document.getElementById(`exif-${i}`);
        if (el) el.innerHTML = '<span class="exif-none">nessun dato EXIF</span>';
      });
    }

    previewGrid.querySelectorAll('.preview-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = parseInt((btn as HTMLElement).dataset.index || '0');
        selectedFiles.splice(idx, 1);
        syncInputFiles();
        renderPreviews();
      });
    });
  }

  function syncInputFiles() {
    const dt = new DataTransfer();
    selectedFiles.forEach(f => dt.items.add(f));
    fileInput.files = dt.files;
  }

  fileInput.addEventListener('change', () => {
    const newFiles = Array.from(fileInput.files ?? []);
    newFiles.forEach(f => {
      if (!selectedFiles.find(s => s.name === f.name && s.size === f.size)) {
        selectedFiles.push(f);
      }
    });
    syncInputFiles();
    renderPreviews();
  });

  clearAllBtn.addEventListener('click', () => {
    selectedFiles = [];
    syncInputFiles();
    renderPreviews();
  });

  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('drag-over');
  });
  dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
  dropZone.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    dropZone.classList.remove('drag-over');
    const files = Array.from(e.dataTransfer?.files ?? []).filter((f: File) => f.type.startsWith('image/'));
    files.forEach((f: File) => {
      if (!selectedFiles.find(s => s.name === f.name && s.size === f.size)) {
        selectedFiles.push(f);
      }
    });
    syncInputFiles();
    renderPreviews();
  });
</script>

<style>
  .admin-wrapper { min-height: 100vh; background: var(--bg-home); }
  .admin-nav { display: flex; justify-content: space-between; align-items: center; padding: 20px 44px; }
  .mono-logo { font-size: 13px; letter-spacing: 2.5px; font-weight: 500; }
  .nav-links { display: flex; gap: 24px; font-size: 10px; letter-spacing: 2px; }
  .nav-links a { color: var(--text-45); text-decoration: none; }
  .nav-links a.active { color: var(--text-primary); }
  .logout-link { color: var(--accent-red); text-decoration: none; }
  .home-link { color: var(--text-primary) !important; border: 1px solid var(--text-45); padding: 4px 10px; font-size: 9px; letter-spacing: 2px; }
  
  .admin-main { padding: 40px 44px; max-width: 1200px; margin: 0 auto; }
  .header-section { margin-bottom: 48px; }
  h1 { font-size: 48px; margin: 0; }
  .alert-success {
    margin-top: 16px;
    background: rgba(232,226,212,0.05);
    border: 1px solid var(--text-14);
    padding: 12px 20px;
    font-size: 12px;
    color: var(--text-primary);
  }

  .grid-section { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; margin-bottom: 48px; }
  .admin-card { border: 1px solid var(--border-subtle); padding: 24px; }
  .card-header { font-size: 10px; letter-spacing: 2.5px; opacity: 0.5; margin-bottom: 24px; }
  
  .admin-form { display: flex; flex-direction: column; gap: 16px; }
  .admin-form .row { display: flex; gap: 16px; }
  input, select {
    width: 100%;
    background: var(--bg-frame);
    border: 1px solid var(--border-subtle);
    padding: 10px 14px;
    color: var(--text-primary);
    font-family: var(--font-mono);
    font-size: 12px;
    outline: none;
  }
  button {
    background: transparent;
    border: 1px solid var(--text-45);
    color: var(--text-primary);
    padding: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 2px;
    cursor: pointer;
  }
  button:hover { background: var(--text-14); }
  button.primary { background: var(--text-primary); color: #000; border: none; }

  .file-input-wrapper { position: relative; border: 1px dashed var(--border-dashed); padding: 24px; text-align: center; transition: border-color 0.15s, background 0.15s; }
  .file-input-wrapper.drag-over { border-color: var(--text-primary); background: rgba(232,226,212,0.04); }
  #file-upload { display: none; }
  .file-label { cursor: pointer; font-size: 10px; letter-spacing: 2px; opacity: 0.7; }

  .preview-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  #preview-count { font-size: 9px; letter-spacing: 2px; opacity: 0.5; }
  #clear-all-btn { background: none; border: none; color: var(--accent-red); font-size: 9px; letter-spacing: 1.5px; padding: 0; cursor: pointer; }

  #preview-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-height: 420px; overflow-y: auto; padding-right: 4px; }
  #preview-grid::-webkit-scrollbar { width: 3px; }
  #preview-grid::-webkit-scrollbar-thumb { background: var(--border-subtle); }

  .preview-card { border: 1px solid var(--border-subtle); background: var(--bg-frame); overflow: hidden; }
  .preview-thumb { position: relative; aspect-ratio: 4/3; overflow: hidden; }
  .preview-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.85; }
  .preview-remove {
    position: absolute; top: 6px; right: 6px;
    background: rgba(0,0,0,0.75); border: none; color: var(--text-primary);
    width: 22px; height: 22px; cursor: pointer; font-size: 9px;
    display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.15s;
  }
  .preview-card:hover .preview-remove { opacity: 1; }
  .preview-remove:hover { background: var(--accent-red); }

  .preview-info { padding: 8px 10px; }
  .preview-filename { font-size: 9px; letter-spacing: 0.5px; opacity: 0.5; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-bottom: 5px; }
  .preview-exif { display: flex; flex-wrap: wrap; gap: 4px; }
  .exif-tag { font-size: 8px; letter-spacing: 1px; padding: 2px 5px; border: 1px solid var(--border-subtle); opacity: 0.7; }
  .exif-loading { font-size: 8px; opacity: 0.3; letter-spacing: 1px; }
  .exif-none { font-size: 8px; opacity: 0.25; letter-spacing: 1px; }

  .stories-list { margin-top: 48px; }
  .stories-grid { display: flex; flex-direction: column; gap: 12px; }
  .story-item { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border: 1px solid var(--border-subtle); }
  .story-title { font-size: 20px; margin-right: 16px; }
  .story-meta { font-size: 10px; color: var(--text-45); }
  .story-actions { display: flex; gap: 16px; font-size: 10px; letter-spacing: 1.5px; align-items: center; }
  .story-actions a { color: var(--text-primary); text-decoration: none; border-bottom: 1px solid var(--text-primary); }
  .delete-story-form { display: inline; }
  .delete-btn { color: var(--accent-red); border: none; background: none; padding: 0; font-size: 10px; cursor: pointer; letter-spacing: 1.5px; }

  .print-requests-section { margin-top: 64px; padding-top: 48px; border-top: 1px solid var(--border-subtle); }
  .empty-requests { font-size: 11px; opacity: 0.35; letter-spacing: 1px; padding: 24px 0; }
  .print-requests-grid { display: flex; flex-direction: column; gap: 12px; margin-top: 20px; }

  .print-request-card {
    display: grid;
    grid-template-columns: 80px 1fr auto;
    gap: 20px;
    align-items: start;
    padding: 16px 20px;
    border: 1px solid var(--border-subtle);
    background: rgba(232,226,212,0.015);
  }
  .print-request-card.status-confirmed { border-color: rgba(100,180,100,0.3); }
  .print-request-card.status-shipped   { border-color: rgba(100,100,220,0.3); }
  .print-request-card.status-closed    { opacity: 0.45; }

  .req-thumb { width: 80px; height: 60px; overflow: hidden; background: var(--bg-frame); flex-shrink: 0; }
  .req-thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.8; }

  .req-body { display: flex; flex-direction: column; gap: 4px; }
  .req-meta { font-size: 9px; letter-spacing: 1.5px; opacity: 0.45; }
  .req-lbl { font-size: 16px; }
  .req-specs { font-size: 9px; letter-spacing: 1.5px; opacity: 0.6; }
  .req-contact { font-size: 11px; margin-top: 2px; }
  .req-contact a { color: var(--text-primary); }
  .req-notes { font-size: 11px; opacity: 0.55; font-style: italic; margin-top: 4px; }

  .req-actions { display: flex; flex-direction: column; align-items: flex-end; gap: 10px; }
  .req-status { font-size: 8px; letter-spacing: 2px; padding: 3px 8px; border: 1px solid var(--border-subtle); }
  .status-badge-pending   { color: var(--text-45); }
